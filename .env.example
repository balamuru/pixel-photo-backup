# Source root directory containing subdirectories of photos to back up
SRC_DIR=/path/to/your/source/directory

# Optional: Override the Pixel DCIM Camera mount path
# If left blank, the tool will attempt to dynamically locate it under /run/user/<uid>/gvfs/
PIXEL_CAMERA_DIR=

# Optional: The maximum cumulative size of virtual batches in MB when processing flat directories (default: 2000)
BATCH_SIZE_MB=2000

# Path to the local staging directory where media from the source phone is saved (first stage)
# If left blank, pull_source_media.py will default to using the value of SRC_DIR
LOCAL_STAGE_DIR=

# Optional: Override the source phone mount path (not the Pixel device)
# If left blank, pull_source_media.py will attempt to auto-detect any non-Pixel MTP mount path
SOURCE_PHONE_DIR=
